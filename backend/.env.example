# Copy this file to `.env` and fill in the values below.
# For Gmail, create an App Password and use that as SMTP_PASSWORD.
# For Supabase, use your project URL and a backend-only key.

PORT=8000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_TABLE=inquiries
SUPABASE_SERVICE_KEY=your-service-role-or-secret-key
SCHOOL_NOTIFICATION_EMAIL=st.judesfnr@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=st.judesfnr@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=st.judesfnr@gmail.com
SMTP_USE_SSL=true
SMTP_STARTTLS=false
